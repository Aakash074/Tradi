# =============================================================================
# Tradi — environment template (copy to .env and fill in values)
# =============================================================================

# --- TWAK (Trust Wallet Agent Kit) ---
# Password from: twak wallet create --password <pwd>
# Required for competition swaps and wallet sync
TWAK_ACCESS_ID=your_access_id
TWAK_HMAC_SECRET=your_hmac_secret
TWAK_AGENT_PASSWORD=secure_password

# --- CoinMarketCap ---
# Required for live prices when using --live-cmc (or LIVE_CMC=1)
# OHLCV candles: tries CMC /v2/ohlcv/historical (Startup+ plan), else Binance public klines (no extra key)
CMC_API_KEY=your_cmc_pro_api_key
# Optional separate key for CMC Agent Hub MCP; falls back to CMC_API_KEY
# CMC_MCP_API_KEY=

# --- Agent mode ---
# paper | competition | live
# Tournament YAML auto-loads when AGENT_MODE=competition (config/tournament_week.yaml)
AGENT_MODE=paper
COMPETITION_START=2026-06-22T00:00:00Z
COMPETITION_END=2026-06-28T23:59:59Z
# Auto-switch paper → competition at COMPETITION_START (UTC), back at COMPETITION_END
COMPETITION_AUTO_SWITCH=true
# Paper swaps + real TWAK wallet balance sync (no on-chain gas). CLI: --dry-run
COMPETITION_DRY_RUN=false

# --- Live CMC ---
# Prefer CLI flag: python -m tradi.agent --live-cmc
# LIVE_CMC=1

# --- x402 micropayments (CMC premium MCP on Base) ---
# Requires TWAK wallet funded with USDC. CLI: --x402
X402_ENABLED=false
X402_MAX_PAYMENT_USDC=0.01

# --- Risk (backend/config.py → risk_manager) ---
# Confluence daily loss limit also comes from config/*.yaml (production: 0.05)
MAX_DRAWDOWN_HALT=0.25
MAX_DRAWDOWN_DQ=0.30
DAILY_LOSS_HALT=0.05
MAX_POSITION_PCT=0.25
MAX_TRADES_PER_DAY=5
MAX_CONCURRENT_POSITIONS=3

# --- Advisory gate (optional veto-only review, fail-open if unreachable) ---
ADVISORY_GATE_ENABLED=false
ADVISORY_GATE_API_KEY=
OPENAI_API_KEY=
ADVISORY_GATE_MODEL=gpt-3.5-turbo

# --- Database (async SQLAlchemy — keep aiosqlite driver) ---
DATABASE_URL=sqlite+aiosqlite:///./tradi.db

# --- API / dashboard ---
API_SECRET=your_api_secret_for_cron
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional analytics (not wired in V3 main path) ---
ARKHAM_API_KEY=
NANSEN_API_KEY=

# Note: BNB Agent SDK (bnbagent) is open-source — ERC-8004 identity uses TWAK
# wallet password, not a hosted API key. No BNB_SDK_API_KEY needed.
