# TWAK Configuration
TWAK_ACCESS_ID=your_access_id
TWAK_HMAC_SECRET=your_secret
TWAK_AGENT_PASSWORD=secure_password

# CoinMarketCap
CMC_API_KEY=your_cmc_key

# BNB AI Agent SDK
BNB_SDK_API_KEY=your_bnb_key

# Agent Configuration
AGENT_MODE=paper
COMPETITION_START=2026-06-22T00:00:00Z
